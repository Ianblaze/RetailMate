# RetailMate POS Environment Variables

# -------------------------
# DATABASE SETUP
# -------------------------
# The connection string for your PostgreSQL database.
# In local Docker dev, this isn't strictly necessary since we default to the internal container,
# but it's required for Railway or when running the backend without Docker.
# DB_URL=jdbc:postgresql://localhost:5432/retailmate
# DB_USERNAME=postgres
# DB_PASSWORD=postgres

# -------------------------
# EXTERNAL SERVICES
# -------------------------
# The URL where the AI Service (Python Flask) is running.
# When deployed on Railway, replace this with the public generic URL Railway gives the AI service.
# AI_SERVICE_URL=http://localhost:5000

# -------------------------
# EMAIL CONFIGURATION
# -------------------------
# The email credentials used for sending automated receipts and notifications.
# MUST BE FILLED to avoid errors when the app tries to send an email.
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password
